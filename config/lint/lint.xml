<?xml version="1.0" encoding="UTF-8"?>
<lint>
	<!-- Translations are crowdsourced -->
	<issue id="MissingTranslation" severity="ignore" />
	<issue id="MissingQuantity" severity="ignore" />
	<issue id="ExtraTranslation" severity="ignore" />

	<!-- Temporarily disable -->
	<issue id="ImpliedQuantity" severity="ignore" />
	<issue id="InflateParams" severity="ignore" />
	<issue id="ObsoleteSdkInt" severity="ignore" />
	<issue id="OldTargetApi" severity="ignore" />
	<issue id="AndroidGradlePluginVersion" severity="ignore" />

	<!-- The app uses legacy back handling throughout, and does not opt in to
	     predictive back (enableOnBackInvokedCallback is unset), so
	     onBackPressed() is still called at runtime. Remove this when
	     migrating to OnBackPressedDispatcher. -->
	<issue id="GestureBackNavigation" severity="ignore" />

	<!-- Too many false positives -->
	<issue id="UnusedResources" severity="ignore" />

	<!-- Not an issue -->
	<issue id="ViewConstructor" severity="ignore" />
	<issue id="GradleDependency" severity="ignore" />

	<!-- Caused by 3rd party dependencies/jetification -->
	<issue id="ObsoleteLintCustomCheck" severity="ignore" />

	<!-- We don't use app bundles -->
	<issue id="AppBundleLocaleChanges" severity="ignore" />

	<!-- Resource shrinking is deliberately disabled -->
	<issue id="NotShrinkingResources" severity="ignore" />

</lint>
